{
    "initializationAction": "(q.npc.is_in_battle_with(q.player) || !q.npc.is_doing_activity('minecraft:idle', 'cobblemon:battling')) ? q.dialogue.close()",
    "speakers": {
        "npc": {
            "name": "Gym Leader Norman",
            "face": "q.npc.face(false);"
        },
        "player": {
            "face": "q.player.face();",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "npc-chat",
            "speaker": "npc",
            "lines": [
                "We meet again... You've grown, haven't you. I'm so happy you've made it this far. But... From here on out, I'm not your dad. I'm the Gym Leader of Petalburg! As the Gym Leader, I will use everything at my disposal to crush you!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Let's Battle!",
                        "value": "battle",
                        "action": [
                            "q.dialogue.close();",
                            "q.npc.start_battle(q.player, 'single');"
                        ],
                        "isSelectable": "c.npc.can_battle;"
                    },
                    {
                        "text": "Cancel",
                        "value": "cancel",
                        "action": [
                            "q.dialogue.close()"
                        ]
                    }
                ]
            }
        }
    ]
}