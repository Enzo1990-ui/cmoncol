{
    "initializationAction": "(q.npc.is_in_battle_with(q.player) || !q.npc.is_doing_activity('minecraft:idle', 'cobblemon:battling')) ? q.dialogue.close()",
    "speakers": {
        "npc": {
            "name": "Gym Leader Skyla",
            "face": "q.npc.face(false);"
        },
        "player": {
            "face": "q.player.face();",
            "name": {
                "type": "expression",
                "expression": "q.player.username"
            }
        }
    },
    "pages": [
        {
            "id": "npc-chat",
            "speaker": "npc",
            "lines": [
                "Welcome to the Mistralton City Pokemon Gym. I'm Skyla, the Gym Leader. I use Flying-type Pokemon. Let's see if you can handle my high-flying acrobatics!"
            ],
            "input": {
                "type": "option",
                "vertical": false,
                "options": [
                    {
                        "text": "Let's Battle!",
                        "value": "battle",
                        "action": [
                            "q.dialogue.close();",
                            "q.npc.start_battle(q.player, 'single');"
                        ],
                        "isSelectable": "c.npc.can_battle;"
                    },
                    {
                        "text": "Cancel",
                        "value": "cancel",
                        "action": [
                            "q.dialogue.close()"
                        ]
                    }
                ]
            }
        }
    ]
}